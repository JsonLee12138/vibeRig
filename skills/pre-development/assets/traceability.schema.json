{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/traceability.schema.json",
  "title": "VibeRig Requirement Traceability Matrix",
  "type": "object",
  "required": ["version", "requirementId", "links"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "enum": [1, 2] },
    "requirementId": { "type": "string" },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["outcome", "architectureRefs", "acIds", "testCaseIds", "riskIds", "milestoneIds"],
        "additionalProperties": false,
        "properties": {
          "outcome": { "type": "string", "minLength": 1 },
          "architectureRefs": { "type": "array", "items": { "type": "string" } },
          "acIds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^AC-[0-9]+$" } },
          "testCaseIds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^TC-[0-9]+$" } },
          "riskIds": { "type": "array", "items": { "type": "string", "pattern": "^RISK-[0-9]+$" } },
          "milestoneIds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^ms-[0-9]+$" } },
          "issueIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "ownerAcceptanceRequired": { "type": "boolean" },
          "releaseGateIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "version": { "const": 2 } } },
      "then": {
        "properties": {
          "links": {
            "items": {
              "required": ["issueIds", "ownerAcceptanceRequired", "releaseGateIds"]
            }
          }
        }
      }
    }
  ]
}
