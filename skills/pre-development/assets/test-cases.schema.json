{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/test-cases.schema.json",
  "title": "VibeRig Pre-development Test Cases",
  "type": "object",
  "required": ["version", "requirementId", "cases"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "enum": [1, 2] },
    "requirementId": { "type": "string" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "level", "acIds", "preconditions", "steps", "expected", "automation", "evidence"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^TC-[0-9]+$" },
          "title": { "type": "string", "minLength": 1 },
          "level": { "type": "string", "enum": ["unit", "integration", "contract", "e2e", "regression", "performance", "security", "manual"] },
          "acIds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^AC-[0-9]+$" } },
          "preconditions": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "expected": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "automation": { "type": "string", "enum": ["required", "recommended", "manual", "not_applicable"] },
          "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "executionStage": { "type": "string", "enum": ["issue_local", "pr_ci", "milestone", "owner_uat", "post_release"] },
          "required": { "type": "boolean" },
          "environment": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["local", "ci", "staging", "production_like", "production"] }
          },
          "riskLevel": { "type": "string", "enum": ["low", "standard", "high"] },
          "gateRef": { "type": ["string", "null"] },
          "timeoutSeconds": { "type": ["integer", "null"], "minimum": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "version": { "const": 2 } } },
      "then": {
        "properties": {
          "cases": {
            "items": {
              "required": ["executionStage", "required", "environment", "riskLevel"]
            }
          }
        }
      }
    }
  ]
}
