{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/risk-register.schema.json",
  "title": "VibeRig Pre-development Risk Register",
  "type": "object",
  "required": ["version", "requirementId", "risks"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "requirementId": { "type": "string" },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "description", "probability", "impact", "trigger", "mitigation", "fallback", "owner", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^RISK-[0-9]+$" },
          "category": { "type": "string", "enum": ["product", "architecture", "data", "security", "compliance", "delivery", "operations", "dependency"] },
          "description": { "type": "string", "minLength": 1 },
          "probability": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "trigger": { "type": "string", "minLength": 1 },
          "mitigation": { "type": "string", "minLength": 1 },
          "fallback": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["open", "mitigated", "accepted", "closed"] }
        }
      }
    }
  }
}
