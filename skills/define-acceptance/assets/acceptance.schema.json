{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/acceptance.schema.json",
  "title": "VibeRig Acceptance Criteria",
  "type": "object",
  "required": ["version", "requirement", "criteria"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "enum": [1, 2] },
    "requirement": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source", "precondition", "action", "expected", "evidence", "verification", "milestone"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
          "source": { "type": "string", "minLength": 1 },
          "precondition": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 },
          "expected": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 },
          "milestone": { "type": ["string", "null"] },
          "expectedData": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "expectedVisual": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "failureSignals": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "verificationStatus": { "type": "string", "enum": ["planned", "implemented", "verified", "accepted", "rejected"] },
          "ownerVerification": {
            "type": "object",
            "required": ["objective", "environment", "entrypoint", "actor", "setup", "steps", "evidence", "cleanup"],
            "additionalProperties": false,
            "properties": {
              "objective": { "type": "string", "minLength": 1 },
              "environment": { "type": "string", "minLength": 1 },
              "entrypoint": { "type": "string", "minLength": 1 },
              "actor": { "type": "string", "minLength": 1 },
              "setup": { "type": "array", "items": { "type": "string" } },
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["action", "expected"],
                  "additionalProperties": false,
                  "properties": {
                    "action": { "type": "string", "minLength": 1 },
                    "expected": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "cleanup": { "type": "array", "items": { "type": "string" } }
            }
          },
          "engineeringVerification": {
            "type": "object",
            "required": ["commands", "checks", "levels", "residualRisk"],
            "additionalProperties": false,
            "properties": {
              "commands": { "type": "array", "items": { "type": "string" } },
              "checks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "levels": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "enum": ["unit", "integration", "contract", "e2e", "regression", "performance", "security", "manual"] }
              },
              "residualRisk": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "version": { "const": 2 } },
        "required": ["version"]
      },
      "then": {
        "properties": {
          "criteria": {
            "items": {
              "required": [
                "id", "source", "precondition", "action", "expected", "evidence",
                "verification", "milestone", "ownerVerification", "engineeringVerification",
                "expectedData", "expectedVisual", "failureSignals", "verificationStatus"
              ],
              "properties": {
                "milestone": { "type": ["string", "null"], "pattern": "^ms-[0-9]+$" }
              }
            }
          }
        }
      }
    }
  ]
}
