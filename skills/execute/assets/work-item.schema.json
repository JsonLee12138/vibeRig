{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/work-item.schema.json",
  "title": "VibeRig Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "origin",
    "problem",
    "expectedOutcome",
    "evidence",
    "causalModel",
    "proposedChange",
    "alternatives",
    "impact",
    "scope",
    "acceptanceOracle",
    "testStrategy",
    "risk",
    "dependencies",
    "deliveryTarget",
    "status"
  ],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" },
    "origin": {
      "type": "string",
      "enum": ["defect", "limitation", "opportunity", "maintenance", "risk"]
    },
    "problem": { "type": "string", "minLength": 1 },
    "expectedOutcome": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "reference", "summary"],
        "properties": {
          "type": { "type": "string" },
          "reference": { "type": ["string", "null"] },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "causalModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "explanation", "confidence", "validation"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["confirmed", "hypothesis", "not_applicable"]
        },
        "explanation": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "validation": { "type": ["string", "null"] }
      }
    },
    "proposedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "rationale"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["option", "decision"],
        "properties": {
          "option": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 }
        }
      }
    },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["users", "behavior", "interfaces", "data", "security", "operations", "blastRadius"],
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "behavior": { "type": "array", "items": { "type": "string" } },
        "interfaces": { "type": "array", "items": { "type": "string" } },
        "data": { "type": "array", "items": { "type": "string" } },
        "security": { "type": "array", "items": { "type": "string" } },
        "operations": { "type": "array", "items": { "type": "string" } },
        "blastRadius": { "type": "string", "minLength": 1 }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["included", "excluded", "affectedModules"],
      "properties": {
        "included": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "excluded": { "type": "array", "items": { "type": "string" } },
        "affectedModules": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptanceOracle": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "condition", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]+$" },
          "condition": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 }
        }
      }
    },
    "testStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["levels", "environment", "minimumFidelity", "humanBoundary"],
      "properties": {
        "levels": { "type": "array", "items": { "type": "string" } },
        "environment": { "type": "string", "minLength": 1 },
        "minimumFidelity": {
          "type": "string",
          "enum": ["mock", "fake", "stub", "ephemeral", "sandbox", "real"]
        },
        "humanBoundary": { "type": ["string", "null"] }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reasons", "upgradeSignals"],
      "properties": {
        "level": { "type": "string", "enum": ["L0", "L1", "L2", "L3"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "upgradeSignals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "mockable", "notes"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "mockable": { "type": "boolean" },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "deliveryTarget": {
      "type": "string",
      "enum": ["diagnosed", "recorded", "planned", "verified", "committed", "pr_ready", "merged", "released"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "awaiting_confirmation", "baselined", "executing", "pending_acceptance", "accepted", "rejected"]
    }
  }
}
