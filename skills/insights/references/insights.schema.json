{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viberig.local/schemas/insights.schema.json",
  "title": "VibeRig Retrospective Evidence",
  "type": "object",
  "required": [
    "scope_id",
    "scope_type",
    "status",
    "event_kind",
    "source_kind",
    "retrospective_signals",
    "discarded_signals"
  ],
  "properties": {
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_type": {
      "type": "string",
      "enum": ["issue", "milestone", "requirement", "non_code_outcome"]
    },
    "requirement_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "done"]
    },
    "event_kind": {
      "type": "string",
      "enum": ["acceptance", "aggregation"]
    },
    "source_kind": {
      "type": "string",
      "enum": ["code", "non_code", "aggregate"]
    },
    "acceptance_event": {
      "type": "object",
      "required": ["id", "record"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^acceptance:[^:]+:.+:r[1-9][0-9]*$"
        },
        "record": {
          "type": "string",
          "minLength": 1
        },
        "accepted_at": {
          "type": "string",
          "format": "date-time"
        },
        "accepted_by": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "aggregation_event": {
      "type": "object",
      "required": ["id", "derived_from"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Canonical full lowercase SHA-256 digest of the LF-joined, raw-UTF-8-bytewise-sorted derived_from IDs.",
          "pattern": "^aggregate:[^:]+:[a-f0-9]{64}$"
        },
        "derived_from": {
          "description": "Exact unique child acceptance event IDs used to recompute and verify the aggregation digest.",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^acceptance:[^:]+:.+:r[1-9][0-9]*$"
          }
        }
      },
      "additionalProperties": true
    },
    "aggregate_only": {
      "type": "boolean"
    },
    "accepted_record": {
      "type": "string",
      "minLength": 1
    },
    "prior_acceptance_events": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^acceptance:[^:]+:.+:r[1-9][0-9]*$"
      }
    },
    "gate": {
      "type": "object",
      "required": ["acceptance_passed", "human_accepted"],
      "properties": {
        "validation_passed": { "type": "boolean" },
        "acceptance_passed": { "const": true },
        "human_accepted": { "const": true },
        "code_review_passed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "delivery_state": {
      "type": "string",
      "enum": [
        "accepted_unmerged",
        "accepted_in_milestone",
        "merged",
        "authoritative_branch",
        "no_merge_required"
      ]
    },
    "sources": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "git": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "accepted_commit": { "type": "string", "minLength": 1 },
        "merged_commit": { "type": "string" },
        "changed_files": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "result": { "type": "string" }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "properties": {
        "acceptance_notes": { "type": "string" },
        "code_review_notes": { "type": "string" },
        "handoff_notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "routing_observations": {
      "type": "array",
      "items": {
        "$ref": "../../subagent-routing/assets/route-observation.schema.json"
      }
    },
    "routing_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_count",
        "comparable_count",
        "excluded_route_ids",
        "comparison_groups",
        "default_changed"
      ],
      "properties": {
        "observation_count": { "type": "integer", "minimum": 0 },
        "comparable_count": { "type": "integer", "minimum": 0 },
        "excluded_route_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "comparison_groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["comparison_key", "sample_count", "incumbent", "decision"],
            "properties": {
              "comparison_key": { "type": "string", "minLength": 1 },
              "sample_count": { "type": "integer", "minimum": 1 },
              "incumbent": { "type": "string", "minLength": 1 },
              "eligible_challenger": { "type": ["string", "null"] },
              "decision": {
                "enum": [
                  "insufficient_samples",
                  "keep_incumbent",
                  "challenger_eligible",
                  "promote_challenger",
                  "block_exploration",
                  "not_comparable"
                ]
              },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "default_changed": { "const": false },
        "next_trial": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["task_family", "model", "reasoning_effort", "eligibility"],
          "properties": {
            "task_family": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "reasoning_effort": { "type": "string", "minLength": 1 },
            "eligibility": { "enum": ["explore", "shadow", "not_eligible"] },
            "why": { "type": "string" }
          }
        }
      }
    },
    "retrospective_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "confidence",
          "evidence",
          "applicability",
          "scope_hint",
          "invalidation_signals"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "applicability": { "type": "string", "minLength": 1 },
          "scope_hint": {
            "type": "string",
            "enum": ["project", "global", "unknown"]
          },
          "invalidation_signals": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "discarded_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "reason": {
            "type": "string",
            "enum": [
              "abandoned_path",
              "not_accepted",
              "transient_environment",
              "one_off",
              "speculative",
              "insufficient_evidence",
              "sensitive"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "residual_risks": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "oneOf": [
        {
          "properties": {
            "event_kind": { "const": "acceptance" },
            "source_kind": { "enum": ["code", "non_code"] }
          },
          "required": ["acceptance_event", "gate", "delivery_state"],
          "not": {
            "anyOf": [
              { "required": ["aggregation_event"] },
              { "required": ["aggregate_only"] }
            ]
          }
        },
        {
          "properties": {
            "event_kind": { "const": "aggregation" },
            "source_kind": { "const": "aggregate" },
            "scope_type": { "const": "requirement" },
            "aggregate_only": { "const": true }
          },
          "required": ["aggregation_event", "aggregate_only"],
          "not": {
            "anyOf": [
              { "required": ["acceptance_event"] },
              { "required": ["gate"] }
            ]
          }
        }
      ]
    },
    {
      "if": {
        "properties": {
          "event_kind": { "const": "acceptance" },
          "source_kind": { "const": "code" }
        }
      },
      "then": {
        "required": ["git"],
        "properties": {
          "git": {
            "required": ["accepted_commit"]
          },
          "gate": {
            "required": ["validation_passed", "code_review_passed"],
            "properties": {
              "validation_passed": { "const": true },
              "code_review_passed": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_kind": { "const": "acceptance" },
          "source_kind": { "const": "non_code" }
        }
      },
      "then": {
        "required": ["accepted_record"]
      }
    }
  ],
  "additionalProperties": true
}
