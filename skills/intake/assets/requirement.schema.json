{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/requirement.schema.json",
  "title": "VibeRig Requirement Traceability (requirement.yaml)",
  "type": "object",
  "required": ["version", "requirement", "milestones"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "requirement": {
      "type": "object",
      "required": ["id", "title", "status", "prd", "created"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "语义 slug（全小写 kebab-case，如 payment-refactor）；兼容历史 req-NNNN",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": [
            "intake",
            "requirement_baselined",
            "pre_development",
            "pre_development_blocked",
            "awaiting_owner_approval",
            "conditionally_approved",
            "ready_for_development",
            "planned",
            "in_progress",
            "accepted",
            "archived"
          ]
        },
        "prd": {
          "type": ["string", "null"],
          "description": "关联 PRD id；无 PRD 或尚未完成自动判断时为 null",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "created": { "type": "string", "format": "date" },
        "planning": {
          "type": "object",
          "required": ["prd_decision", "prd_reason", "owner_approval", "approved_at"],
          "additionalProperties": false,
          "properties": {
            "prd_decision": { "type": "string", "enum": ["pending", "existing", "create", "not_required"] },
            "prd_reason": { "type": ["string", "null"] },
            "owner_approval": { "type": "string", "enum": ["pending", "approved", "conditional", "rejected"] },
            "approved_at": { "type": ["string", "null"], "format": "date-time" }
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "description": "开发前为本地草案；老板批准后由 split-milestones 写入 Linear id",
      "items": {
        "type": "object",
        "required": ["id", "linear_id", "title", "module", "ac_ids", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^(ms-[0-9]+|M[0-9]+)$" },
          "linear_id": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "module": { "type": "string", "description": "兼容字段；填写主要交付域，不作为里程碑切分依据" },
          "ac_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^AC-[0-9]+$" }
          },
          "status": {
            "type": "string",
            "enum": ["draft", "not_started", "in_progress", "pending_acceptance", "accepted"]
          }
        }
      }
    }
  }
}
