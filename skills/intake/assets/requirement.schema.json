{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://viberig.dev/schemas/requirement.schema.json",
  "title": "VibeRig Requirement Traceability (requirement.yaml)",
  "type": "object",
  "required": ["version", "requirement", "milestones"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "requirement": {
      "type": "object",
      "required": ["id", "title", "status", "prd", "created"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^req-[0-9]{4}$" },
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["intake", "planned", "in_progress", "accepted", "archived"]
        },
        "prd": {
          "type": ["string", "null"],
          "description": "关联 PRD id（如 prd-0001），无 PRD 时为 null",
          "pattern": "^prd-[0-9]{4}$"
        },
        "created": { "type": "string", "format": "date" }
      }
    },
    "milestones": {
      "type": "array",
      "description": "由 split-milestones 回填；intake 时为空数组",
      "items": {
        "type": "object",
        "required": ["id", "linear_id", "title", "module", "ac_ids", "status"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^ms-[0-9]+$" },
          "linear_id": { "type": "string" },
          "title": { "type": "string" },
          "module": { "type": "string" },
          "ac_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^AC-[0-9]+$" }
          },
          "status": {
            "type": "string",
            "description": "四态：未开始 → 进行中 → 待验收 → 已验收",
            "enum": ["not_started", "in_progress", "pending_acceptance", "accepted"]
          }
        }
      }
    }
  }
}
