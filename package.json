{
  "name": "vibe-rig",
  "type": "module",
  "version": "1.2.1",
  "packageManager": "pnpm@9.15.9",
  "description": "Enterprise pre-development orchestration, approval-ready Docs as Code contracts, Linear-native execution, and subagent routing.",
  "license": "MIT",
  "homepage": "https://github.com/JsonLee12138/vibeRig#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/JsonLee12138/vibeRig.git"
  },
  "bugs": {
    "url": "https://github.com/JsonLee12138/vibeRig/issues"
  },
  "bin": {
    "viberig": "./dist/cli/index.js",
    "vb": "./dist/cli/index.js",
    "vibe-rig": "./dist/cli/index.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "README.zh-CN.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src scripts/*.mjs eslint.config.js tsdown.config.ts package.json tsconfig.json .github/workflows/*.yml",
    "lint:fix": "eslint src scripts/*.mjs eslint.config.js tsdown.config.ts package.json tsconfig.json .github/workflows/*.yml --fix",
    "typecheck": "tsc --noEmit",
    "test:learning-flow": "node scripts/validate-learning-flow.mjs",
    "test": "pnpm run typecheck && pnpm run test:learning-flow"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "fs-extra": "^11.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.10",
    "eslint": "^10.6.0",
    "eslint-plugin-format": "^2.0.1",
    "tsdown": "^0.13.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
