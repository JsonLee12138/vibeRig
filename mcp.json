{
  "mcpServers": {
    "vb-linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": ["--app", "desktop", "--agent", "codexCLI"]
    },
    "qmd": {
      "command": "npx",
      "args": ["-y", "@tobilu/qmd", "mcp"]
    }
  }
}
